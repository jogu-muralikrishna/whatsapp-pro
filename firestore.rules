rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // whatsapp_pro_users root and all inner subcollections/documents
    match /whatsapp_pro_users/{userId} {
      allow read, write: if true;
      
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    // users collections and all inner backup structures
    match /users/{phone} {
      allow read, write: if true;
      
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    // Settings matched collection (legacy/compatibility)
    match /whatsapp_pro/settings {
      allow read, write: if true;
    }

    // Contacts collection matches (legacy/compatibility)
    match /whatsapp_pro_contacts/{contactId} {
      allow read, write: if true;
    }

    // Chats collection matches (legacy/compatibility)
    match /whatsapp_pro_chats/{chatId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
